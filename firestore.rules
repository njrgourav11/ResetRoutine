rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if request is from the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Match users documents and subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /cravings/{cravingId} {
        allow read, write: if isOwner(userId);
      }

      match /gymCheckins/{checkinId} {
        allow read, write: if isOwner(userId);
      }

      match /alcoholCravings/{cravingId} {
        allow read, write: if isOwner(userId);
      }

      match /premiumRequests/{requestId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
